<script>
  function copyEmail() {
    const email = 'sales@desertrich.com';
    navigator.clipboard.writeText(email).then(() => {
      const btns = document.querySelectorAll('button');
      btns.forEach(btn => {
        if (btn.innerText.includes('Copy Contact')) {
          const original = btn.innerHTML;
          btn.innerHTML = '<span>Copied!</span>';
          setTimeout(() => { btn.innerHTML = original; }, 2000);
        }
      });
    }).catch(() => {
      window.location.href = 'mailto:' + email;
    });
  }

  // Hover effects for value cards
  document.querySelectorAll('.clean-section').forEach(card => {
    card.addEventListener('mouseenter', () => {
      card.style.transform = 'translateY(-3px)';
      card.style.boxShadow = '0 20px 25px -5px rgb(0 0 0 / 0.08), 0 8px 10px -6px rgb(0 0 0 / 0.08)';
    });
    card.addEventListener('mouseleave', () => {
      card.style.transform = '';
      card.style.boxShadow = '';
    });
  });

  console.log('%c[phxwax.ing] Premium domain landing ready.', 'color:#B85C38');
</script>
