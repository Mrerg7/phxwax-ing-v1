# Prevent indexing of /index.html duplicate URLs
# Cloudflare Pages serves both / and /index.html for the same content
# X-Robots-Tag: noindex tells Google not to index the /index.html variant
/index.html
  X-Robots-Tag: noindex
/*/index.html
  X-Robots-Tag: noindex

# HTTP Link canonical header for every page
# Ensures Cloudflare Pages sends the correct canonical in HTTP headers
# complementing the inline <link rel="canonical"> 
/*
  Link: <https://phxwax.ing>; rel="canonical"

# Sitemap Content-Type
/sitemap.xml
  Content-Type: application/xml
/sitemap-index.xml
  Content-Type: application/xml
/sitemap-0.xml
  Content-Type: application/xml
